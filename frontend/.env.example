# Frontend Environment Variables
# Copy this to .env.local and fill in real values.
# .env.local is gitignored and will NOT be committed.

# URL of the deployed backend (Render, etc.)
# For local development without Docker, use:
#   VITE_API_URL=http://127.0.0.1:8000
# For Docker Compose (docker compose up), this is set automatically.
# For production (Vercel), set this in Vercel dashboard → Settings → Environment Variables
VITE_API_URL=http://127.0.0.1:8000
